# 1Password secret references consumed by `op run --env-file=op.env -- ...`
# Update the vault/item/field paths below to match your 1Password vault layout,
# then scripts/deploy.sh will inject these as real env vars for the duration
# of each command - nothing plaintext ever touches disk.
TF_VAR_cloudflare_api_token="op://Services/Cloudflare User API Token/password"
AWS_ACCESS_KEY_ID="op://Services/scdt4gjukmsztb3bp2nxouuq34/access_key"
AWS_SECRET_ACCESS_KEY="op://Services/scdt4gjukmsztb3bp2nxouuq34/secret_access_key"
